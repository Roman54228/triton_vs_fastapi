      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(model_inference_duration_seconds_bucket[1m]))",
          "legendFormat": "{{model_name}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(model_inference_duration_seconds_bucket[1m]))",
          "legendFormat": "{{model_name}} p95",
          "refId": "B"
        }
