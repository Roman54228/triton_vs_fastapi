  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": -8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nv_gpu_utilization * 100",
          "legendFormat": "GPU {{gpu_uuid}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GPU Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": -8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "bytes"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nv_gpu_memory_used_bytes",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "nv_gpu_memory_total_bytes",
          "legendFormat": "Total",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GPU Power Usage (W)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": -16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "watt"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nv_gpu_power_usage",
          "legendFormat": "Power",
          "refId": "A"
        },
        {
          "expr": "nv_gpu_power_limit",
          "legendFormat": "Limit",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Triton — Inference Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(nv_inference_request_success[1m])",
          "legendFormat": "{{model}} — success",
          "refId": "A"
        },
        {
          "expr": "rate(nv_inference_request_failure[1m])",
          "legendFormat": "{{model}} — failure",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Triton — Inference Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "µs"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(nv_inference_compute_infer_duration_us[1m]) / clamp_min(rate(nv_inference_request_success[1m]), 1)",
          "legendFormat": "{{model}} — compute",
          "refId": "A"
        },
        {
          "expr": "rate(nv_inference_queue_duration_us[1m]) / clamp_min(rate(nv_inference_request_success[1m]), 1)",
          "legendFormat": "{{model}} — queue",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Triton — Inflight Request Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nv_inference_pending_request_count",
          "legendFormat": "{{model}} — pending",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Triton — Total Requests (counter)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "nv_inference_request_success",
          "legendFormat": "{{model}} — success",
          "refId": "A"
        },
        {
          "expr": "nv_inference_request_failure",
          "legendFormat": "{{model}} — failure",
          "refId": "B"
        }
      ]
    },
    {
      "title": "FastAPI — Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(inference_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "FastAPI — Request Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(inference_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(inference_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(inference_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
